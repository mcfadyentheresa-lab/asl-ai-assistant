# ============================================================================
# Aster & Spruce Connect — Environment Variables
# ============================================================================
# Copy this file to .env for local development, or paste these values into
# Railway's "Variables" tab for deployment.

# --- REQUIRED (app won't boot without these) ---

# PostgreSQL connection string.
# On Railway: set to ${{ Postgres.DATABASE_URL }}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign session cookies. Any long random string (32+ chars).
# Generate one: run `openssl rand -hex 32` or use https://1password.com/password-generator
SESSION_SECRET=replace-me-with-a-long-random-string

# Node environment. Set to "production" on Railway.
NODE_ENV=production

# --- AUTHENTICATION ---
# This app was originally built with Replit Auth (only works on Replit).
# Set this to true on Railway to bypass login so you can use the app.
# ⚠️  With this set to true, ANYONE who opens the URL becomes an admin.
#     Do NOT share the URL until proper auth is added.
OPENID_DISABLED=true

# --- OPTIONAL (features that need them) ---

# OpenAI — for the AI Scope Analyzer in Cost Estimator
OPENAI_API_KEY=sk-...

# Twilio — for SMS notifications and client invites
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Nodemailer — for email (optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Google Cloud Storage — for photo/document uploads (optional)
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=
