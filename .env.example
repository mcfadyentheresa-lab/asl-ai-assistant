# =============================================================================
#  Aster & Spruce — environment template
# =============================================================================
# Copy to .env (or set on Railway) and fill in real values. Never commit .env.
# =============================================================================

# --- Required ----------------------------------------------------------------
# Postgres connection string. Production: use a managed Postgres (Railway/Neon/
# Supabase). Local dev: any local Postgres works.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Cookie signing secret. Generate with:  openssl rand -base64 32
SESSION_SECRET=

# --- Recommended -------------------------------------------------------------
# Canonical public URL. Used in invite & password-reset email links.
APP_URL=https://app.asterandspruce.com

# Node environment. "production" turns on secure cookies and disables the dev
# auth bypass.
NODE_ENV=production

# --- Email (invites, password resets) ----------------------------------------
# Gmail account + Google App Password. Without these, invites & resets are
# created but no email is sent.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Object storage (Google Cloud Storage) -----------------------------------
# Pick ONE of GCS_CREDENTIALS_JSON or GCS_KEY_FILE.
# GCS_CREDENTIALS_JSON: paste the entire service-account JSON key as a string.
# Easiest on Railway — no file management.
GCS_PROJECT_ID=
GCS_CREDENTIALS_JSON=
# GCS_KEY_FILE=/path/to/service-account.json

# Bucket paths used by the app. Format: /<bucket-name>/<prefix>
# PRIVATE_OBJECT_DIR is where new uploads go.
# PUBLIC_OBJECT_SEARCH_PATHS is a comma-separated list of read-only roots.
PRIVATE_OBJECT_DIR=/your-bucket/private
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public

# --- Google Drive export (optional) ------------------------------------------
# For the "Export social posts to Google Drive" feature. Without these, the
# feature returns 503 with a clear message. Setup steps in DEPLOYMENT.md.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# GOOGLE_OAUTH_REDIRECT_URI=

# --- AI / OpenAI (optional but most features depend on this) ----------------
OPENAI_API_KEY=

# --- SMS notifications (optional) -------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Dev only ---------------------------------------------------------------
# Set AUTH_DEV_BYPASS=true to short-circuit authentication and act as an
# always-on admin user. Honored ONLY when NODE_ENV != "production".
# AUTH_DEV_BYPASS=true

# --- Bootstrap admin (one-shot, optional) ------------------------------------
# If set, `npm run bootstrap:admin` will run non-interactively. Leave blank to
# be prompted. Unset these after the first admin is created.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_FIRST_NAME=
# ADMIN_LAST_NAME=
